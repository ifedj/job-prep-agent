# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# Google OAuth — create at https://console.cloud.google.com/
# 1. Create a project, enable Calendar API and Gmail API
# 2. Create OAuth 2.0 credentials (Web Application type)
# 3. Add http://localhost:8000/auth/google/callback as an Authorized Redirect URI
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Security — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-real-secret-key

# Token encryption key — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=generate-me-with-fernet

# App config
DATABASE_URL=sqlite:///./job_prep.db
SYNC_INTERVAL_MINUTES=30

# Classification thresholds (0.0 to 1.0)
# Events above HIGH_CONFIDENCE get auto-processed
# Events between AMBIGUOUS_LOWER and HIGH_CONFIDENCE go to review queue
# Events below AMBIGUOUS_LOWER are ignored
CLASSIFICATION_HIGH_CONFIDENCE=0.85
CLASSIFICATION_AMBIGUOUS_LOWER=0.65
